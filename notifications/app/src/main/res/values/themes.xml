<resources xmlns:tools="http://schemas.android.com/tools">

    <!-- Базовая тема приложения (всегда тёмная) -->
    <style name="Theme.Notifications" parent="Theme.MaterialComponents.NoActionBar">
        <!-- Основной акцент -->
        <item name="colorPrimary">@color/dark_primary</item>
        <item name="colorPrimaryVariant">@color/dark_primary_variant</item>
        <item name="colorOnPrimary">@color/dark_on_primary</item>

        <!-- Второй акцент -->
        <item name="colorSecondary">@color/dark_secondary</item>
        <item name="colorSecondaryVariant">@color/dark_secondary</item>
        <item name="colorOnSecondary">@color/black</item>

        <!-- Фоны / поверхности -->
        <item name="android:windowBackground">@color/dark_background</item>
        <item name="colorSurface">@color/dark_surface</item>
        <item name="colorOnSurface">@color/dark_text_primary</item>
        <item name="android:colorBackground">@color/dark_background</item>

        <!-- Текст -->
        <item name="android:textColorPrimary">@color/dark_text_primary</item>
        <item name="android:textColorSecondary">@color/dark_text_secondary</item>
        <item name="android:textColorHint">@color/dark_text_hint</item>

        <!-- Статус-бар / навигация -->
        <item name="android:statusBarColor" tools:targetApi="l">@color/dark_background</item>
        <item name="android:navigationBarColor" tools:targetApi="l">@color/dark_background</item>
        <item name="android:windowLightStatusBar" tools:targetApi="m">false</item>

        <!-- Стили кнопок по умолчанию -->
        <item name="materialButtonStyle">@style/Widget.App.Button</item>
    </style>

    <!-- Тема для прозрачного диалогового Activity -->
    <style name="Theme.Notifications.Dialog" parent="Theme.MaterialComponents.Dialog.Alert">
        <item name="colorPrimary">@color/dark_primary</item>
        <item name="colorPrimaryVariant">@color/dark_primary_variant</item>
        <item name="colorOnPrimary">@color/dark_on_primary</item>
        <item name="colorSurface">@color/dark_surface</item>
        <item name="colorOnSurface">@color/dark_text_primary</item>
        <item name="android:textColorPrimary">@color/dark_text_primary</item>
        <item name="android:textColorSecondary">@color/dark_text_secondary</item>
        <item name="android:windowBackground">@drawable/bg_dialog</item>
    </style>

    <!-- Стиль основной кнопки -->
    <style name="Widget.App.Button" parent="Widget.MaterialComponents.Button">
        <item name="backgroundTint">@color/dark_primary</item>
        <item name="android:textColor">@color/dark_on_primary</item>
        <item name="cornerRadius">12dp</item>
        <item name="android:textAllCaps">false</item>
        <item name="android:letterSpacing">0.02</item>
    </style>

    <!-- Кнопка-опасность (Нет/Отменить) -->
    <style name="Widget.App.Button.Danger" parent="Widget.App.Button">
        <item name="backgroundTint">@color/dark_danger</item>
        <item name="android:textColor">@color/black</item>
    </style>

    <!-- Нейтральная кнопка -->
    <style name="Widget.App.Button.Neutral" parent="Widget.App.Button">
        <item name="backgroundTint">@color/dark_neutral</item>
        <item name="android:textColor">@color/dark_text_primary</item>
    </style>
</resources>