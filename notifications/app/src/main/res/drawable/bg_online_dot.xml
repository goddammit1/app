<?xml version="1.0" encoding="utf-8"?>
<!--
    Bright green presence dot pinned to the bottom-right corner of an
    avatar in the users list. The dark outer ring isolates it from the
    avatar underneath.
-->
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <item>
        <shape android:shape="oval">
            <solid android:color="@color/bg_root" />
        </shape>
    </item>
    <item
        android:left="2dp" android:top="2dp"
        android:right="2dp" android:bottom="2dp">
        <shape android:shape="oval">
            <solid android:color="@color/status_ready_fg" />
        </shape>
    </item>
</layer-list>