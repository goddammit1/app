<?xml version="1.0" encoding="utf-8"?>
<!--
    "Ready" slot: same dark base + bright white 2dp outline.
    The thin outer rim emulates a subtle glow.
-->
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <item>
        <shape android:shape="rectangle">
            <solid android:color="@color/accent_white_dim" />
            <corners android:radius="14dp" />
        </shape>
    </item>
    <item
        android:left="2dp" android:top="2dp"
        android:right="2dp" android:bottom="2dp">
        <shape android:shape="rectangle">
            <solid android:color="@color/bg_slot_idle" />
            <stroke android:width="2dp" android:color="@color/accent_white" />
            <corners android:radius="12dp" />
        </shape>
    </item>
</layer-list>