<?xml version="1.0" encoding="utf-8"?>
<!--
    Custom drawable for the response timer ProgressBar.
    Track:    subtle translucent white pill.
    Progress: white -> transparent horizontal gradient inside rounded clip.
-->
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">

    <!-- background track -->
    <item android:id="@android:id/background">
        <shape android:shape="rectangle">
            <solid android:color="@color/timer_track" />
            <corners android:radius="999dp" />
        </shape>
    </item>

    <!-- actual progress -->
    <item android:id="@android:id/progress">
        <clip>
            <shape android:shape="rectangle">
                <gradient
                    android:angle="0"
                    android:type="linear"
                    android:startColor="@color/accent_white"
                    android:endColor="@android:color/transparent" />
                <corners android:radius="999dp" />
            </shape>
        </clip>
    </item>
</layer-list>