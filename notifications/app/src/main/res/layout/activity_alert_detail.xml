<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/dark_background"
    android:fillViewport="true"
    tools:context=".AlertDetailActivity">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <TextView
            android:id="@+id/headerDate"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textColor="@color/dark_text_hint"
            android:textSize="13sp"
            android:layout_marginTop="8dp"
            tools:text="14.05 22:30" />

        <TextView
            android:id="@+id/headerText"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textColor="@color/dark_text_primary"
            android:textSize="20sp"
            android:textStyle="bold"
            android:layout_marginTop="4dp"
            tools:text="Get ready" />

        <TextView
            android:id="@+id/headerSummary"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textColor="@color/dark_text_secondary"
            android:textSize="14sp"
            android:layout_marginTop="6dp"
            tools:text="3 / 5 responded" />

        <!-- READY -->
        <TextView
            android:id="@+id/sectionReady"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textColor="@color/status_ready_fg"
            android:textSize="14sp"
            android:textStyle="bold"
            android:layout_marginTop="24dp"
            android:layout_marginBottom="8dp"
            tools:text="Ready (2)" />

        <LinearLayout
            android:id="@+id/listReady"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical" />

        <!-- NOT READY -->
        <TextView
            android:id="@+id/sectionNotReady"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textColor="@color/status_not_ready_fg"
            android:textSize="14sp"
            android:textStyle="bold"
            android:layout_marginTop="24dp"
            android:layout_marginBottom="8dp"
            tools:text="Not ready (1)" />

        <LinearLayout
            android:id="@+id/listNotReady"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical" />

        <!-- NO RESPONSE -->
        <TextView
            android:id="@+id/sectionPending"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textColor="@color/status_pending_fg"
            android:textSize="14sp"
            android:textStyle="bold"
            android:layout_marginTop="24dp"
            android:layout_marginBottom="8dp"
            tools:text="No response (2)" />

        <LinearLayout
            android:id="@+id/listPending"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:layout_marginBottom="24dp" />

    </LinearLayout>
</ScrollView>