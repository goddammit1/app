<?xml version="1.0" encoding="utf-8"?>
<!--
    Main screen, redesigned.

    Layout (top to bottom):
        - "Notifications" title, centered top.
        - Status panel: rounded dark container with 5 equally-spaced
          square slots and a thin timer progress bar underneath.
          The slots correspond to the first five responses to the
          most recent broadcast (sorted by response time).
        - Bottom footer with a single chevron-up icon button that
          opens the menu bottom-sheet.

    Every drawable referenced here lives in res/drawable/bg_*.xml so the
    designer can tweak look-and-feel without touching the layout.
-->
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_panel"
    tools:context=".MainActivity">

    <!-- Title -->
    <TextView
        android:id="@+id/titleText"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/main_title"
        android:textColor="@color/text_primary"
        android:textSize="22sp"
        android:textStyle="bold"
        android:fontFamily="sans-serif"
        android:layout_marginTop="48dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- Status panel (5 slots + timer) -->
    <LinearLayout
        android:id="@+id/statusPanel"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="@drawable/bg_status_panel"
        android:padding="20dp"
        android:layout_marginStart="24dp"
        android:layout_marginEnd="24dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <!-- 5 status slots in a row -->
        <LinearLayout
            android:id="@+id/statusSlots"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:weightSum="5"
            android:baselineAligned="false">

            <FrameLayout
                android:id="@+id/slot1"
                android:layout_width="0dp"
                android:layout_height="0dp"
                android:layout_weight="1"
                android:layout_marginEnd="8dp"
                android:background="@drawable/bg_slot_idle"
                android:clipToOutline="true">
                <ImageView
                    android:id="@+id/slot1Avatar"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:scaleType="centerCrop"
                    android:visibility="gone"
                    android:contentDescription="@null" />
            </FrameLayout>

            <FrameLayout
                android:id="@+id/slot2"
                android:layout_width="0dp"
                android:layout_height="0dp"
                android:layout_weight="1"
                android:layout_marginStart="4dp"
                android:layout_marginEnd="4dp"
                android:background="@drawable/bg_slot_idle"
                android:clipToOutline="true">
                <ImageView
                    android:id="@+id/slot2Avatar"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:scaleType="centerCrop"
                    android:visibility="gone"
                    android:contentDescription="@null" />
            </FrameLayout>

            <FrameLayout
                android:id="@+id/slot3"
                android:layout_width="0dp"
                android:layout_height="0dp"
                android:layout_weight="1"
                android:layout_marginStart="4dp"
                android:layout_marginEnd="4dp"
                android:background="@drawable/bg_slot_idle"
                android:clipToOutline="true">
                <ImageView
                    android:id="@+id/slot3Avatar"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:scaleType="centerCrop"
                    android:visibility="gone"
                    android:contentDescription="@null" />
            </FrameLayout>

            <FrameLayout
                android:id="@+id/slot4"
                android:layout_width="0dp"
                android:layout_height="0dp"
                android:layout_weight="1"
                android:layout_marginStart="4dp"
                android:layout_marginEnd="4dp"
                android:background="@drawable/bg_slot_idle"
                android:clipToOutline="true">
                <ImageView
                    android:id="@+id/slot4Avatar"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:scaleType="centerCrop"
                    android:visibility="gone"
                    android:contentDescription="@null" />
            </FrameLayout>

            <FrameLayout
                android:id="@+id/slot5"
                android:layout_width="0dp"
                android:layout_height="0dp"
                android:layout_weight="1"
                android:layout_marginStart="8dp"
                android:background="@drawable/bg_slot_idle"
                android:clipToOutline="true">
                <ImageView
                    android:id="@+id/slot5Avatar"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:scaleType="centerCrop"
                    android:visibility="gone"
                    android:contentDescription="@null" />
            </FrameLayout>

        </LinearLayout>

        <!-- Response timer -->
        <ProgressBar
            android:id="@+id/timerBar"
            style="?android:attr/progressBarStyleHorizontal"
            android:layout_width="match_parent"
            android:layout_height="4dp"
            android:layout_marginTop="20dp"
            android:max="1000"
            android:progress="0"
            android:progressDrawable="@drawable/bg_timer_progress" />

    </LinearLayout>

    <!--
        Workaround: LinearLayout doesn't honour layout_constraintDimensionRatio,
        so the 5 slots above use square aspect via a separate sizing pass in
        MainActivity (we set the layout_height to match the slot's width).
        See MainActivity#applySlotSizing.
    -->

    <!-- Bottom chevron-up = open menu -->
    <!--
        Menu button.

        Sized in dp so it stays visually identical across screen densities
        rather than locking to a single physical size. The padding inside
        the button gives us a comfortable touch target (~44dp) without
        making the icon itself look oversized.
    -->
    <ImageButton
        android:id="@+id/btnMenu"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginBottom="20dp"
        android:padding="10dp"
        android:background="?attr/selectableItemBackgroundBorderless"
        android:contentDescription="@string/menu_open"
        android:src="@drawable/ic_menu_handle"
        android:scaleType="fitCenter"
        android:adjustViewBounds="true"
        android:maxWidth="36dp"
        android:maxHeight="36dp"
        app:tint="@color/accent_white"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>