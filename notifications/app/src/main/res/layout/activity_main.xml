<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/dark_background"
    android:padding="16dp"
    tools:context=".MainActivity">

    <TextView
        android:id="@+id/titleText"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:text="@string/main_title"
        android:textColor="@color/dark_text_primary"
        android:textSize="24sp"
        android:textStyle="bold"
        android:layout_marginTop="24dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toStartOf="@id/btnLogout" />

    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnLogout"
        style="@style/Widget.App.Button.Neutral"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/main_logout"
        android:textSize="13sp"
        android:minWidth="0dp"
        android:minHeight="0dp"
        android:paddingStart="14dp"
        android:paddingEnd="14dp"
        app:layout_constraintTop_toTopOf="@id/titleText"
        app:layout_constraintBottom_toBottomOf="@id/titleText"
        app:layout_constraintEnd_toEndOf="parent" />

    <TextView
        android:id="@+id/welcomeText"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:textColor="@color/dark_text_secondary"
        android:textSize="14sp"
        android:layout_marginTop="6dp"
        app:layout_constraintTop_toBottomOf="@id/titleText"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        tools:text="Signed in as: alice" />

    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnPickUser"
        style="@style/Widget.App.Button"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:text="@string/main_pick_user"
        android:minHeight="56dp"
        android:layout_marginTop="32dp"
        app:layout_constraintTop_toBottomOf="@id/welcomeText"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnBroadcast"
        style="@style/Widget.App.Button.Neutral"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:text="@string/main_broadcast"
        android:minHeight="56dp"
        android:layout_marginTop="12dp"
        app:layout_constraintTop_toBottomOf="@id/btnPickUser"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnOnlineUsers"
        style="@style/Widget.App.Button.Neutral"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:text="@string/main_online_users"
        android:minHeight="56dp"
        android:layout_marginTop="12dp"
        app:layout_constraintTop_toBottomOf="@id/btnBroadcast"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnReports"
        style="@style/Widget.App.Button.Neutral"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:text="@string/main_reports"
        android:minHeight="56dp"
        android:layout_marginTop="12dp"
        app:layout_constraintTop_toBottomOf="@id/btnOnlineUsers"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnPickSound"
        style="@style/Widget.App.Button.Neutral"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:text="@string/main_pick_sound"
        android:minHeight="56dp"
        android:layout_marginTop="12dp"
        app:layout_constraintTop_toBottomOf="@id/btnReports"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <TextView
        android:id="@+id/soundStatus"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:textColor="@color/dark_text_hint"
        android:textSize="12sp"
        android:gravity="center"
        android:layout_marginTop="6dp"
        app:layout_constraintTop_toBottomOf="@id/btnPickSound"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        tools:text="Sound: Default" />

    <!-- Discreet helpers in the bottom corners -->
    <TextView
        android:id="@+id/btnRequestOverlay"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/main_request_overlay"
        android:textColor="@color/dark_text_hint"
        android:textSize="11sp"
        android:padding="12dp"
        android:alpha="0.55"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent" />

    <TextView
        android:id="@+id/btnSelfTest"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="self-test"
        android:textColor="@color/dark_text_hint"
        android:textSize="11sp"
        android:padding="12dp"
        android:alpha="0.55"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>
